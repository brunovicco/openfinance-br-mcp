{
  "mcpServers": {
    "openfinance-br": {
      "command": "uvx",
      "args": [
        "--from",
        "openfinance-br-mcp==0.2.0",
        "openfinance-mcp"
      ],
      "env": {
        "ENVIRONMENT": "mock",
        "MTLS_ENABLED": "false",
        "LOG_FORMAT": "console",
        "DSPY_CACHE_ENABLED": "true"
      }
    }
  }
}
