# openfinance-br-mcp - environment variables
# Copy to .env and fill in your real values.
# NEVER commit .env to the repository.

# Open Finance credentials (registered with the participating institution)
CLIENT_ID=your_client_id_here
PRIVATE_KEY_PATH=certs/client-signing-key.pem
PRIVATE_KEY_KID=your_registered_kid

# mTLS (required for production, optional for sandbox)
MTLS_ENABLED=true
MTLS_CERT_PATH=certs/client.crt
MTLS_KEY_PATH=certs/client.key

# Consent
REDIRECT_URI=https://localhost:8080/callback
CONSENT_EXPIRY_HOURS=720

# DSPy/Categorization
# Only needed for categorize=true on the transaction tools
ANTHROPIC_API_KEY=sk-ant-...
DSPY_MODEL=anthropic/claude-haiku-4-5-20251001
DSPY_CACHE_ENABLED=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console   # "json" in production, "console" in dev

# Langfuse
LANGFUSE_SECRET_KEY=sk-
LANGFUSE_PUBLIC_KEY=pk-
LANGFUSE_OTLP_ENDPOINT="https://us.cloud.langfuse.com/api/public/otel"

# HTTP
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3

# MCP client OAuth 2.1 (streamable-http transport auth)
# Leave both unset to run the HTTP transport without MCP client auth (only
# safe because MCP_HTTP_HOST defaults to loopback). Set both together once a
# real identity provider exists - see docs/en/authorization.md.
# MCP_OAUTH_ISSUER_URL=https://your-idp.example.com
# MCP_OAUTH_RESOURCE_SERVER_URL=https://your-mcp-server.example.com
# MCP_OAUTH_REQUIRED_SCOPES=
# Required together with a non-loopback MCP_HTTP_HOST:
# MCP_HTTP_ALLOWED_ORIGINS=["https://your-mcp-server.example.com"]

# Shared state backend (TokenStore/ConsentManager)
# Leave unset for in-memory storage (fine for a single process/mock mode).
# Required for correctness if you run more than one replica - see
# auth/redis_backend.py and k8s/config-and-secrets.yaml.
# REDIS_URL=redis://localhost:6379/0
